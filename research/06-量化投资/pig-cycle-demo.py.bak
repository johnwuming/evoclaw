COLORS = {
    'pig_price':      '#E74C3C',   # 红色 - 猪价
    'breeding_sow':   '#3498DB',   # 蓝色 - 能繁母猪
    'piglet_price':   '#F39C12',   # 橙色 - 仔猪价格
    'pig_corn_ratio': '#27AE60',   # 绿色 - 猪粮比
    'corn':           '#9B59B6',   # 紫色 - 玉米
    'soybean':        '#1ABC9C',   # 青色 - 豆粕
    'inventory':      '#E67E22',   # 深橙 - 生猪存栏
    'profit':         '#2ECC71',   # 亮绿 - 养殖利润
    'stock':          '#2980B9',   # 深蓝 - 股票
    'etf':            '#8E44AD',   # 紫红 - ETF
}

# ============================================================
# 模拟数据生成函数
# ============================================================

def generate_date_range(start_year=2022, end_year=2026, freq='W'):
    """生成日期序列（2022-01 至 2026-04，周度数据）"""
    start = datetime(start_year, 1, 1)
    end = datetime(end_year, 4, 6)
    dates = pd.date_range(start=start, end=end, freq=freq)
    return dates


def generate_pig_cycle_data():
    """
    生成模拟猪周期数据，贴近真实规律：
    - 3-4年一个完整周期
    - 2022年高点、2024年低点、2026年处于复苏阶段
    
    猪价规律：10个月滞后于能繁母猪变化
    """
    dates = generate_date_range(2022, 2026, freq='W')
    n = len(dates)
    
    # 时间索引（以周为单位）
    t = np.arange(n)
    
    # ---- 能繁母猪存栏（万头）----
    # 周期：约52周 × 3.5年 ≈ 182周
    # 基准3900万头，波动 ±500万头
    sow_cycle = 180  # 周期长度（周）
    sow = 4000 + 500 * np.sin(2 * np.pi * t / sow_cycle - np.pi * 0.3)
    # 叠加一些噪声
    np.random.seed(42)
    sow += np.random.normal(0, 30, n)
    # 趋势：2025年后有所下降（去产能）
    trend = np.where(t > 150, -80 * np.ones(n), 0)
    sow = sow + trend
    sow = np.clip(sow, 3300, 4500)
    
    # ---- 猪价（元/kg）----
    # 领先能繁母猪约10个月（即滞后10个月×52/12≈43周）
    # 猪价与能繁母猪负相关（滞后约43周）
    price_cycle = 180
    price_phase = t / price_cycle * 2 * np.pi - np.pi * 0.3 - 2 * np.pi * 43 / price_cycle
    pig_price = 18 + 8 * np.sin(price_phase)
    np.random.seed(43)
    pig_price += np.random.normal(0, 0.5, n)
    # 2026年初跌破10元/kg（接近历史低点）
    pig_price = np.clip(pig_price, 8, 26)
    
    # ---- 仔猪价格（元/kg）----
    # 领先猪价约2-3个月（26周）
    piglet_phase = t / price_cycle * 2 * np.pi - np.pi * 0.3 - 2 * np.pi * 30 / price_cycle
    piglet_price = 35 + 20 * np.sin(piglet_phase)
    np.random.seed(44)
    piglet_price += np.random.normal(0, 1.5, n)
    piglet_price = np.clip(piglet_price, 15, 55)
    
    # ---- 猪粮比 ----
    # 盈亏平衡约5.5:1，当前约4.5-5.0（2026年初亏损状态）
    corn_price = 2.5 + 0.3 * np.sin(2 * np.pi * t / 52 + 1)
    np.random.seed(45)
    corn_price += np.random.normal(0, 0.05, n)
    corn_price = np.clip(corn_price, 2.0, 3.2)
    
    pig_corn_ratio = pig_price / corn_price
    # 叠加噪声
    pig_corn_ratio += np.random.normal(0, 0.1, n)
    
    # ---- 玉米价格（元/kg）----
    corn = corn_price
    
    # ---- 豆粕价格（元/kg）----
    soybean = 3.8 + 0.6 * np.sin(2 * np.pi * t / 52 + 2)
    np.random.seed(46)
    soybean += np.random.normal(0, 0.1, n)
    soybean = np.clip(soybean, 3.0, 5.0)
    
    # ---- 生猪存栏（万头）----
    inventory_cycle = 180
    inventory = 45000 + 8000 * np.sin(2 * np.pi * t / inventory_cycle - np.pi * 0.2)
    np.random.seed(47)
    inventory += np.random.normal(0, 500, n)
    inventory = np.clip(inventory, 35000, 55000)
    
    # ---- 养殖利润（元/头，自繁自养）----
    # 成本约12元/kg，出栏体重约120kg
    cost_per_kg = 12.0
    weight = 120
    profit = (pig_price - cost_per_kg) * weight
    np.random.seed(48)
    profit += np.random.normal(0, 50, n)
    
    df = pd.DataFrame({
        'date': dates,
        'pig_price': pig_price,
        'breeding_sow': sow,
        'piglet_price': piglet_price,
        'pig_corn_ratio': pig_corn_ratio,
        'corn_price': corn,
        'soybean_meal': soybean,
        'inventory': inventory,
        'profit': profit,
    })
    
    return df


def normalize_minmax(series):
    """最大最小值归一化到 0-1 范围"""
    mn = series.min()
    mx = series.max()
    if mx == mn:
        return pd.Series([0.5] * len(series), index=series.index)
    return (series - mn) / (mx - mn)


def generate_stock_data():
    """
    生成模拟股票/ETF价格数据（2022-01 至 2026-04）
    贴近真实规律：猪价上涨时畜牧养殖股票走强
    """
    dates = generate_date_range(2022, 2026, freq='W')
    n = len(dates)
    t = np.arange(n)
    
    # 牧原股份 (002714) - 行业龙头，成本最低
    np.random.seed(50)
    muyuan_base = 50 + 15 * np.sin(2 * np.pi * t / 180 - np.pi * 0.3)
    muyuan = muyuan_base + np.random.normal(0, 2, n)
    muyuan = np.clip(muyuan, 30, 80)
    
    # 温氏股份 (300498) - 第二大
    np.random.seed(51)
    wenshi_base = 18 + 5 * np.sin(2 * np.pi * t / 180 - np.pi * 0.3)
    wenshi = wenshi_base + np.random.normal(0, 0.8, n)
    wenshi = np.clip(wenshi, 10, 28)
    
    # 畜牧ETF (159867)
    np.random.seed(52)
    etf_base = 0.7 + 0.25 * np.sin(2 * np.pi * t / 180 - np.pi * 0.3)
    etf = etf_base + np.random.normal(0, 0.03, n)
    etf = np.clip(etf, 0.4, 1.1)
    
    # 养殖ETF (159865)
    np.random.seed(53)
    etf2_base = 0.65 + 0.22 * np.sin(2 * np.pi * t / 180 - np.pi * 0.25)
    etf2 = etf2_base + np.random.normal(0, 0.025, n)
    etf2 = np.clip(etf2, 0.35, 1.0)
    
    # 基准指数（沪深300）用于对比
    np.random.seed(54)
    hs300 = 4000 + 600 * np.sin(2 * np.pi * t / 180 + 0.5)
    hs300 += np.random.normal(0, 80, n)
    
    df = pd.DataFrame({
        'date': dates,
        'muyuan': muyuan,       # 牧原股份
        'wenshi': wenshi,       # 温氏股份
        'livestock_etf': etf,  # 畜牧ETF 159867
        'breed_etf': etf2,      # 养殖ETF 159865
        'hs300': hs300,         # 沪深300
    })
    
    return df


# ============================================================
# 图表1：全指标归一化叠加图
# ============================================================
def plot_all_indicators_normalized(df, output_path):
    """
    全指标归一化叠加图
    所有指标做最大最小值归一化（0-1），展示领先/滞后关系
    """
    fig, ax = plt.subplots(figsize=(16, 8))
    
    # 归一化各指标
    plot_data = pd.DataFrame({'date': df['date']})
    plot_data['猪价'] = normalize_minmax(df['pig_price'])
    plot_data['能繁母猪'] = normalize_minmax(df['breeding_sow'])
    plot_data['仔猪价格'] = normalize_minmax(df['piglet_price'])
    plot_data['猪粮比'] = normalize_minmax(df['pig_corn_ratio'])
    plot_data['养殖利润'] = normalize_minmax(df['profit'])
    plot_data['生猪存栏'] = normalize_minmax(df['inventory'])
    
    # 绘制各指标折线
    ax.plot(plot_data['date'], plot_data['猪价'], 
            color=COLORS['pig_price'], linewidth=2, label='猪价 (pig price)', alpha=0.9)
    ax.plot(plot_data['date'], plot_data['能繁母猪'], 
            color=COLORS['breeding_sow'], linewidth=2, label='能繁母猪 (breeding sow)', alpha=0.9)
    ax.plot(plot_data['date'], plot_data['仔猪价格'], 
            color=COLORS['piglet_price'], linewidth=2, label='仔猪价格 (piglet price)', alpha=0.9)
    ax.plot(plot_data['date'], plot_data['猪粮比'], 
            color=COLORS['pig_corn_ratio'], linewidth=2, label='猪粮比 (pig-corn ratio)', alpha=0.9)
    ax.plot(plot_data['date'], plot_data['养殖利润'], 
            color=COLORS['profit'], linewidth=2, label='养殖利润 (breeding profit)', alpha=0.9)
    ax.plot(plot_data['date'], plot_data['生猪存栏'], 
            color=COLORS['inventory'], linewidth=2, label='生猪存栏 (pig inventory)', alpha=0.9)
    
    # 标注周期阶段
    # 在图上用背景色标注周期阶段
    ax.axvspan(datetime(2024, 6, 1), datetime(2025, 12, 31), 
               alpha=0.08, color='red', label='下行期')
    ax.axvspan(datetime(2022, 1, 1), datetime(2023, 6, 30), 
               alpha=0.08, color='orange', label='上行期')
    
    # 添加周期阶段文字标注
    ax.annotate('周期顶部\n(2022高点)', xy=(datetime(2022, 4, 1), 0.95),
                fontsize=10, ha='center', color='darkred',
                bbox=dict(boxstyle='round,pad=0.3', facecolor='white', alpha=0.7))
    ax.annotate('产能过剩\n猪价低迷', xy=(datetime(2024, 10, 1), 0.05),
                fontsize=10, ha='center', color='darkred',
                bbox=dict(boxstyle='round,pad=0.3', facecolor='white', alpha=0.7))
    ax.annotate('复苏初期', xy=(datetime(2026, 1, 15), 0.55),
                fontsize=10, ha='center', color='darkgreen',
                bbox=dict(boxstyle='round,pad=0.3', facecolor='white', alpha=0.7))
    
    # 标注领先/滞后关系箭头
    ax.annotate('', xy=(datetime(2023, 6, 1), 0.85), 
                xytext=(datetime(2022, 8, 1), 0.85),
                arrowprops=dict(arrowstyle='->', color='gray', lw=1.5))
    ax.text(datetime(2023, 1, 1), 0.87, '能繁母猪领先猪价约10个月', 
            fontsize=9, color='gray', ha='center')
    
    ax.set_title('全指标归一化叠加图（2022-2026）\nAll Indicators Normalized (Min-Max 0-1 Scale)',
                 fontsize=14, fontweight='bold', pad=15)
    ax.set_xlabel('日期 (Date)', fontsize=11)
    ax.set_ylabel('归一化值 Normalized Value (0-1)', fontsize=11)
    ax.set_ylim(-0.05, 1.1)
    ax.legend(loc='upper right', fontsize=9, ncol=2)
    ax.grid(True, alpha=0.3)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%Y-%m'))
    ax.xaxis.set_major_locator(mdates.MonthLocator(interval=6))
    plt.xticks(rotation=45)
    
    # 数据来源标注
    fig.text(0.99, 0.01, '⚠️ 模拟数据 (Simulated Data) — 演示用途，非真实数据', 
             fontsize=8, ha='right', va='bottom', color='gray')
    
    plt.tight_layout()
    plt.savefig(output_path, dpi=150, bbox_inches='tight')
    plt.close()
    print(f"✅ 图表1已保存: {output_path}")


# ============================================================
# 图表2：猪价走势图
# ============================================================
def plot_pig_price(df, output_path):
    """猪价走势图"""
    fig, ax = plt.subplots(figsize=(14, 6))
    
    ax.plot(df['date'], df['pig_price'], color=COLORS['pig_price'], linewidth=2)
    
    # 标注周期高点/低点
    # 找到近似高点和低点
    price = df['pig_price'].values
    dates = df['date']
    
    # 标注2022年高点（约20+元/kg）
    peak_idx = np.argmax(price[:len(price)//3])
    ax.annotate(f'2022年高点\n{price[peak_idx]:.1f}元/kg', 
                xy=(dates.iloc[peak_idx], price[peak_idx]),
                xytext=(dates.iloc[peak_idx] + timedelta(days=60), price[peak_idx] + 1.5),
                arrowprops=dict(arrowstyle='->', color='darkred'),
                fontsize=10, color='darkred', fontweight='bold')
    
    # 标注2024年低点（约11元/kg）
    low_idx = np.argmin(price[len(price)//3:2*len(price)//3]) + len(price)//3
    ax.annotate(f'2024年低点\n{price[low_idx]:.1f}元/kg', 
                xy=(dates.iloc[low_idx], price[low_idx]),
                xytext=(dates.iloc[low_idx] + timedelta(days=60), price[low_idx] - 2),
                arrowprops=dict(arrowstyle='->', color='darkred'),
                fontsize=10, color='darkred', fontweight='bold')
    
    # 标注2026年初跌破10元
    late_idx = int(len(price) * 0.85)
    ax.annotate(f'2026年初\n跌破10元\n{price[late_idx]:.1f}元/kg', 
                xy=(dates.iloc[late_idx], price[late_idx]),
                xytext=(dates.iloc[late_idx] + timedelta(days=30), price[late_idx] - 1.5),
                arrowprops=dict(arrowstyle='->', color='darkred'),
                fontsize=10, color='darkred', fontweight='bold')
    
    # 成本线
    ax.axhline(y=12, color='gray', linestyle='--', linewidth=1.5, label='行业成本线 (~12元/kg)')
    # 盈亏平衡线（猪粮比5.5:1对应，假设玉米2.5元/kg）
    ax.axhline(y=13.75, color='orange', linestyle=':', linewidth=1.5, label='盈亏平衡线 (~13.75元/kg, 猪粮比5.5:1)')
    # 深度亏损线
    ax.axhline(y=10, color='darkred', linestyle='-.', linewidth=1, alpha=0.7, label='心理关口 (10元/kg)')
    
    ax.set_title('外三元生猪价格走势（2022-2026）\nHog Price Trend (Waishan, CNY/kg)', 
                 fontsize=14, fontweight='bold', pad=15)
    ax.set_xlabel('日期 (Date)', fontsize=11)
    ax.set_ylabel('价格（元/kg）', fontsize=11)
    ax.legend(loc='upper right', fontsize=9)
    ax.grid(True, alpha=0.3)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%Y-%m'))
    ax.xaxis.set_major_locator(mdates.MonthLocator(interval=6))
    plt.xticks(rotation=45)
    
    # 数据来源标注
    fig.text(0.99, 0.01, '⚠️ 模拟数据 (Simulated Data) — 演示用途，非真实数据', 
             fontsize=8, ha='right', va='bottom', color='gray')
    
    plt.tight_layout()
    plt.savefig(output_path, dpi=150, bbox_inches='tight')
    plt.close()
    print(f"✅ 图表2已保存: {output_path}")


